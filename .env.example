# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/athena
VALKEY_URL=redis://localhost:6379

# Runtime
ENVIRONMENT=development
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DOMAIN=athena.localhost

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_FILES=30

# Blob storage
BLOB_STORAGE_BACKEND=local
BLOB_STORAGE_LOCAL_ROOT=.data/blobs

# Beatmap mirror
BEATMAP_OFFICIAL_SOURCES_ENABLED=false
BEATMAP_MIRROR_TRUST_POLICY=untrusted
BEATMAP_OSU_CURRENT_URL_TEMPLATE=https://osu.ppy.sh/osu/{beatmap_id}
BEATMAP_OSU_LEGACY_URL_TEMPLATE=https://old.ppy.sh/osu/{beatmap_id}

# Optional: required only when official sources are enabled in development or production
BEATMAP_OFFICIAL_API_CLIENT_ID=
BEATMAP_OFFICIAL_API_CLIENT_SECRET=
BEATMAP_COMMUNITY_MIRROR_URL_TEMPLATES=
