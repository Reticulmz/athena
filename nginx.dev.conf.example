# athena development reverse proxy
# Usage: nginx -p ./ -e .state/nginx/error.log -c ./nginx.dev.conf -g 'daemon off;'
#
# This is a template. Copy to nginx.dev.conf and replace example.com with your domain.
# nginx.dev.conf is gitignored.

worker_processes 1;
pid .state/nginx/nginx.pid;
error_log .state/nginx/error.log;

events {
    worker_connections 64;
}

http {
    client_body_temp_path .state/nginx/client-body;
    proxy_temp_path       .state/nginx/proxy;
    fastcgi_temp_path     .state/nginx/fastcgi;
    uwsgi_temp_path       .state/nginx/uwsgi;
    scgi_temp_path        .state/nginx/scgi;

    access_log .state/nginx/access.log;
    error_log  .state/nginx/error.log;

    # --- HTTP (port 80) ---
    server {
        listen 80;
        server_name
            c.example.com
            c1.example.com
            ce.example.com
            c4.example.com
            c5.example.com
            c6.example.com
            osu.example.com
            a.example.com
            b.example.com
            api.example.com;

        location / {
            proxy_pass http://127.0.0.1:8000;

            # Preserve original Host header
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;

            # WebSocket support (for future SignalR connections)
            proxy_http_version 1.1;
            proxy_set_header Upgrade           $http_upgrade;
            proxy_set_header Connection        "upgrade";
        }
    }

    # --- HTTPS (port 443) ---
    server {
        listen 443 ssl;
        server_name
            c.example.com
            c1.example.com
            ce.example.com
            c4.example.com
            c5.example.com
            c6.example.com
            osu.example.com
            a.example.com
            b.example.com
            api.example.com;

        ssl_certificate     certs/_wildcard.example.com.pem;
        ssl_certificate_key certs/_wildcard.example.com-key.pem;

        location / {
            proxy_pass http://127.0.0.1:8000;

            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;

            proxy_http_version 1.1;
            proxy_set_header Upgrade           $http_upgrade;
            proxy_set_header Connection        "upgrade";
        }
    }
}
